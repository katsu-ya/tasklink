<% if @task.errors.any? %>
  <ul>
    <% @task.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<h1>タスク作成</h1>

<%= form_with model: @task, local: true do |f| %>

  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :description, "内容" %><br>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :status, "ステータス" %><br>
    <%= f.select :status, [["未着手", 0], ["作業中", 1], ["完了", 2]] %>
  </div>

  <div>
    <%= f.submit "作成" %>
  </div>

<% end %>