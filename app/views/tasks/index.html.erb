<div class="max-w-5xl mx-auto mt-10">

  <!-- タイトル -->
  <h1 class="text-2xl font-bold mb-6">
    <% if params[:keyword].present? %>
      「<%= params[:keyword] %>」の検索結果
    <% else %>
      タスク一覧
    <% end %>
  </h1>

  <!-- 新規作成 -->
  <%= link_to "＋ 新規投稿", new_task_path,
      class: "inline-block bg-blue-500 text-white px-4 py-2 rounded mb-4 hover:bg-blue-600" %>

  <!-- 検索 -->
  <div class="flex gap-2 mb-6">
    <%= form_with url: tasks_path, method: :get, local: true, class: "flex gap-2 w-full" do |f| %>
      <%= f.text_field :keyword,
          placeholder: "タイトル検索",
          class: "border rounded px-3 py-2 w-full" %>
      <button class="bg-gray-200 px-4 py-2 rounded hover:bg-gray-300">
        検索
      </button>
    <% end %>

    <% if params[:keyword].present? %>
      <%= link_to "全て表示", tasks_path,
          class: "px-4 py-2 border rounded hover:bg-gray-100" %>
    <% end %>
  </div>

  <!-- タスク一覧 -->
  <% if @tasks.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @tasks.each do |task| %>

        <div class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition">

          <h2 class="text-lg font-bold mb-2">
            <%= task.title %>
          </h2>

          <p class="text-gray-600 mb-3">
            <%= task.description %>
          </p>

          <!-- ステータス -->
          <span class="inline-block px-2 py-1 text-sm rounded
            <%= case task.status
            when "todo" then "bg-gray-300 text-gray-800"
            when "doing" then "bg-blue-300 text-blue-800"
            when "done" then "bg-green-300 text-green-800"
            end %>">
            <%= case task.status
              when "todo" then "📝 未着手"
              when "doing" then "🔥 作業中"
              when "done" then "✅ 完了"
            end %>
          </span>

          <!-- ボタン -->
          <div class="flex gap-2 mt-4">
            <%= link_to "編集", edit_task_path(task),
                class: "text-sm px-3 py-1 border rounded hover:bg-gray-100" %>

            <%= button_to "削除", task_path(task),
                  method: :delete,
                  data: { turbo_confirm: "削除しますか？" },
                  class: "text-sm px-3 py-1 border border-red-400 text-red-500 rounded hover:bg-red-100" %>
          </div>

        </div>

      <% end %>
    </div>
  <% else %>

    <div class="text-center mt-10 text-gray-500">
      <% if params[:keyword].present? %>
        該当するタスクがありません
      <% else %>
        タスクがまだありません
      <% end %>
    </div>

  <% end %>

  <!-- ページネーション -->
  <div class="flex justify-center mt-8">
    <%= paginate @tasks %>
  </div>

</div>



