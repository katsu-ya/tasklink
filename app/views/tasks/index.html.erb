<h1>タスク一覧</h1>

<%= link_to "新規作成", new_task_path %>

<% @tasks.each do |task| %>
  <div>
    <h2><%= task.title %></h2>
    <p><%= task.description %></p>
    <small><%= task.created_at.strftime("%Y-%m-%d") %></small>

    <%= link_to "編集", edit_task_path(task) %>

    <%= button_to "削除", task_path(task), method: :delete, data: { confirm: "本当に削除しますか？" } %>

  </div>
<% end %>

