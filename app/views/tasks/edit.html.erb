<h1>タスク編集</h1>

<%= form_with model: @task, local: true do |f| %>

  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :description, "内容" %><br>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.select :status,
      [["未着手", "todo"], ["作業中", "doing"], ["完了", "done"]],
      class: "form-select"
    %>
  </div>

  <div>
    <%= f.submit "更新" %>
  </div>

<% end %>