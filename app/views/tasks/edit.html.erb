<h1>タスク編集</h1>

<%= form_with model: @task, local: true do |f| %>

  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :description, "内容" %><br>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :status, "ステータス" %><br>
    <%= f.select :status, [["未着手", 0], ["作業中", 1], ["完了", 2]] %>
  </div>

  <div>
    <%= f.submit "更新" %>
  </div>

<% end %>