<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tasklink" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-cache">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Bootstrap（今は一旦残す） -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body class="bg-gray-100 pt-20">

  <!-- ヘッダー -->
  <nav class="navbar navbar-dark bg-dark fixed-top">
    <div class="container-fluid">
      <span class="navbar-brand">TaskLink</span>
    </div>
  </nav>
  
 <!-- フラッシュ -->
<div class="fixed top-20 right-5 z-[9999] space-y-2">
  <% flash.each do |type, message| %>
  <div class="flash-message fixed top-5 right-5 z-[9999]
              px-4 py-2 rounded shadow text-white
              <%= type.to_s == "notice" ? "bg-green-500" : "bg-red-500" %>">
    <%= message %>
  </div>
<% end %>
</div>





  <!-- メイン -->
  <div class="max-w-2xl mx-auto mt-4 bg-white p-6 rounded shadow">
    <%= yield %>
  </div>

</body>
</html>
